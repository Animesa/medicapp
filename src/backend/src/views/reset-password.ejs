<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MedicAPP | Restablecer Contraseña</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/login.css">
</head>

<body>
  <div class="login-container">
    <div class="login-card">
      <div class="logo-wrapper">
        <div class="logo-glass-circle">
          <img src="/images/logo_app.png" alt="MedicAPP Logo" class="logo-icon-img">
        </div>
        <h1>MedicAPP</h1>
      </div>

      <p class="subtitle">Escribe tu nueva contraseña para ingresar al sistema.</p>

      <% if (locals.error) { %>
        <div style="color: #d32f2f; background-color: #fde0e0; padding: 10px; border-radius: 6px; margin-bottom: 20px; text-align: center; font-size: 14px;">
          <%= error %>
        </div>
      <% } %>

      <form action="/login/reset-password" method="POST" class="login-form" onsubmit="return validarPasswords()">
        <input type="hidden" name="token" value="<%= token %>">

        <div class="input-group">
          <label for="password">Nueva Contraseña</label>
          <input type="password" id="password" name="password" placeholder="••••••••" minlength="4" required autofocus>
        </div>

        <div class="input-group">
          <label for="confirmPassword">Confirmar Nueva Contraseña</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="••••••••" minlength="4" required>
        </div>

        <div id="error-message" style="display: none; color: #d32f2f; background-color: #fde0e0; padding: 8px; border-radius: 6px; margin-bottom: 20px; text-align: center; font-size: 13px;">
          Las contraseñas no coinciden.
        </div>

        <button type="submit" class="submit-btn" style="margin-top: 10px;">Cambiar Contraseña</button>
      </form>
    </div>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>

  <script>
    function validarPasswords() {
      const password = document.getElementById('password').value;
      const confirmPassword = document.getElementById('confirmPassword').value;
      const errorMsg = document.getElementById('error-message');

      if (password !== confirmPassword) {
        errorMsg.style.display = 'block';
        return false;
      }
      errorMsg.style.display = 'none';
      return true;
    }
  </script>
</body>

</html>
