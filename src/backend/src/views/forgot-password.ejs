<!DOCTYPE html>
<html lang="es">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>MedicAPP | Recuperar Contraseña</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/login.css">
</head>

<body>
  <div class="login-container">
    <div class="login-card">
      <div class="logo-wrapper">
        <div class="logo-glass-circle">
          <img src="/images/logo_app.png" alt="MedicAPP Logo" class="logo-icon-img">
        </div>
        <h1>MedicAPP</h1>
      </div>

      <p class="subtitle">Ingresa tu correo electrónico para recibir un enlace de recuperación.</p>

      <% if (locals.error) { %>
        <div style="color: #d32f2f; background-color: #fde0e0; padding: 10px; border-radius: 6px; margin-bottom: 20px; text-align: center; font-size: 14px;">
          <%= error %>
        </div>
      <% } %>

      <% if (locals.success) { %>
        <div style="color: #2e7d32; background-color: #e8f5e9; padding: 10px; border-radius: 6px; margin-bottom: 20px; text-align: center; font-size: 14px;">
          <%= success %>
        </div>
      <% } %>

      <form action="/login/forgot-password" method="POST" class="login-form">
        <div class="input-group">
          <label for="email">Correo Electrónico</label>
          <input type="email" id="email" name="email" placeholder="ejemplo@medicapp.com" required autofocus>
        </div>

        <button type="submit" class="submit-btn" style="margin-top: 10px;">Enviar Enlace</button>
        
        <div style="text-align: center; margin-top: 20px;">
          <a href="/login" class="forgot-password" style="font-size: 14px; text-decoration: none; color: #3498db; font-weight: 500;">Volver al Inicio de Sesión</a>
        </div>
      </form>
    </div>

    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
  </div>
</body>

</html>
