{
  "name": "medicapp",
  "private": true,
  "workspaces": [
    "src/frontend",
    "src/backend"
  ],
  "scripts": {
    "dev:frontend": "yarn --cwd src/frontend dev",
    "dev:backend": "yarn --cwd src/backend dev",
    "dev:all": "concurrently \"yarn run dev:frontend\" \"yarn run dev:backend\""
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}